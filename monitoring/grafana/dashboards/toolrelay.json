{
  "title": "ToolRelay API",
  "uid": "toolrelay-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Requests Per Second",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(http_requests_total{job=\"toolrelay-api\"}[5m])",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "100 * rate(http_requests_total{status=~\"5..\"}[5m]) / rate(http_requests_total[5m])",
          "legendFormat": "Error %"
        }
      ]
    },
    {
      "id": 3,
      "title": "p95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_ms_bucket[5m]))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, rate(http_request_duration_ms_bucket[5m]))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tool Executions / min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(toolrelay_executions_total[1m]) * 60",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active API Keys",
      "type": "stat",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        { "expr": "toolrelay_active_api_keys", "legendFormat": "Active Keys" }
      ]
    },
    {
      "id": 6,
      "title": "Registered Tools",
      "type": "stat",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        { "expr": "toolrelay_registered_tools_total", "legendFormat": "Tools" }
      ]
    },
    {
      "id": 7,
      "title": "Total Executions (24h)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "targets": [
        { "expr": "increase(toolrelay_executions_total[24h])", "legendFormat": "Executions" }
      ]
    },
    {
      "id": 8,
      "title": "Process Memory (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 6 },
      "targets": [
        { "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "RSS MB" }
      ]
    }
  ]
}
